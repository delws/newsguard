# Скопіюйте у .env та заповніть. Файл .env НІКОЛИ не потрапляє в git (див. .gitignore).

# PostgreSQL з pgvector (піднімається через docker-compose.yml)
DATABASE_URL=postgresql://newsguard:newsguard@localhost:5432/newsguard

# Groq — безкоштовний тир, реєстрація без картки: https://console.groq.com
GROQ_API_KEY=

# Опціональні провайдери (потрібні лише якщо ввімкнені в config.yaml)
ANTHROPIC_API_KEY=
TOGETHER_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
